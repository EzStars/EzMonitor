# Shared frontend API base URL.
# monitor-app and monitor-test read this file via Vite envDir='../../'.
VITE_API_URL=http://localhost:3000

# Optional explicit report endpoint. If empty, monitor-test falls back to ${VITE_API_URL}/api/monitor/batch.
VITE_MONITOR_REPORT_URL=
VITE_MONITOR_RELEASE=monitor-test-local

# monitor-node runtime settings
PORT=3000
MONGODB_URI=mongodb://localhost:27017/ezmonitor

# CORS allow-list (comma separated). Localhost any-port is allowed by default.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
CORS_ALLOW_LOCALHOST=true

# security and traffic controls
MONITOR_SOURCEMAP_UPLOAD_KEY=replace_with_strong_secret
MONITOR_MAX_BODY_SIZE=8mb
MONITOR_RATE_LIMIT_WINDOW_MS=60000
MONITOR_RATE_LIMIT_MAX=240
